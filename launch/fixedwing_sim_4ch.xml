<launch>
    <arg name="use_joystick" default="true"/>

    <node pkg="cyecca" exec="fixedwing_sim_4ch.py" output="screen"/>
    <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-prefix cyecca)/share/cyecca/config/nvp_sim.config.rviz">
        <param name="use_sim_time" value="true"/>
    </node>
    <node
    pkg="joy"
    exec="joy_node"
    name="joystick"
    output="screen"
    if="$(var use_joystick)"
    />
</launch>
